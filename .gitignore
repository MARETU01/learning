*.a
*.out
*.exe

# Selenium/Drivers
web_crawler_learning/chromedriver-win64/

# Project-specific
# =================
# Python cache in hotel app
hotel/hotel/__pycache__/

# Compiled artifacts & images generated during crawling/tests
web_crawler/**/__pycache__/
web_crawler_learning/**/__pycache__/

# Static generated files (keep originals in versioned static/ but ignore transient)
server/static/leaderboard.txt

# Misc temporary files
*.bak
*.old
*.orig
*.rej

# Coverage/Reports
coverage/
reports/

# Security: common secret files
*.secret
*.key
*.pem
*.crt

# Local config
*.local
*.env.local
.env.*.local

# macOS resource forks (if any cross-platform)
._*

